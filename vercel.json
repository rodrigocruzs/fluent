{
    "builds": [
        {
            "src": "website/**",
            "use": "@vercel/static"
        },
        {
            "src": "api/index.py",
            "use": "@vercel/python",
            "config": { "requirementsFile": "api/requirements.txt" }
        }
    ],
    "routes": [
        { "src": "/api/(.*)", "dest": "/api/index.py" },
        { "src": "/sample-report.html", "dest": "/website/sample-report.html" },
        { "src": "/(.*)", "dest": "/website/$1" }
    ]
}
