{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fluent",
  "version": "0.1.0",
  "identifier": "co.tryfluent.windows",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Fluent",
        "width": 1040,
        "height": 720,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "engine-bundle/**/*"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser"
      },
      "signCommand": "artifact-signing-cli -e https://neu.codesigning.azure.net/ -a fluent -c fluent-public %1"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["fluent"]
      }
    },
    "updater": {
      "endpoints": [
        "https://www.tryfluent.co/windows/updates/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI0OTI3RkQwQkQ0NTVFRjYKUldUMlhrVzkwSCtTdEw3QklRSXRpVG1CbnFrT1VwVmMvTFFtTEZDOVlkN0ZDZ1kraWNKeXQ3cUEK"
    }
  }
}
